{
  "name": "pear-runtime-updater",
  "version": "0.0.2",
  "description": "Listens for OTA Pear App updates",
  "license": "Apache-2.0",
  "author": "Holepunch Inc",
  "main": "index.js",
  "exports": {
    "./package": "./package.json",
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    }
  },
  "files": [
    "package.json",
    "index.js",
    "index.d.ts"
  ],
  "scripts": {
    "format": "prettier . --write",
    "test": "prettier . --check && lunte",
    "lint": "lunte"
  },
  "imports": {
    "fs": {
      "bare": "bare-fs",
      "default": "fs"
    },
    "path": {
      "bare": "bare-path",
      "default": "path"
    }
  },
  "dependencies": {
    "bare-fs": "^4.5.3",
    "bare-path": "^3.0.0",
    "corestore": "^7.8.0",
    "fs-native-extensions": "^1.4.5",
    "hypercore-id-encoding": "^1.3.0",
    "hyperdrive": "^13.2.1",
    "hyperswarm": "^4.16.0",
    "localdrive": "^2.2.0",
    "pear-link": "^4.2.1",
    "ready-resource": "^1.2.0",
    "which-runtime": "^1.3.2"
  },
  "devDependencies": {
    "lunte": "^1.6.0",
    "prettier": "^3.8.1",
    "prettier-config-holepunch": "^2.0.0"
  }
}
