{
  "name": "cli-updater",
  "version": "1.0.0",
  "main": "cli.js",
  "bin": "cli.js",
  "scripts": {
    "start": "node cli.js",
    "build": "pkg . --targets node18-linux-x64,node18-darwin-x64,node18-darwin-arm64,node18-win-x64 --output dist/cli-updater"
  },
  "pkg": {
    "scripts": "cli.js",
    "assets": "package.json",
    "outputPath": "dist"
  },
  "dependencies": {
    "corestore": "^7.8.0",
    "hyperswarm": "^4.16.0",
    "pear-runtime": "^0.4.3"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  }
}
